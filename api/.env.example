# ─────────────────────────────────────────────
# Trivium API — environment configuration
#
# Everything below is OPTIONAL. The scanner runs with zero configuration
# against any public URL. Add keys to unlock specific features.
# ─────────────────────────────────────────────

# Server
PORT=3001
NODE_ENV=development

# Frontend URL — used as the redirect target for OAuth callbacks.
FRONTEND_URL=http://localhost:5173

# ─── Performance check ────────────────────────
# Without a key, Trivium falls back to anonymous PageSpeed Insights API
# (rate-limited). Get a free key at https://developers.google.com/speed/docs/insights/v5/get-started
PSI_API_KEY=

# ─── Optional integrations (OAuth) ────────────
# Each integration is independent. Set up only the ones you want.

# Google Search Console + Google Analytics 4 + Google Ads
# Create OAuth client: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/integrations/gsc/callback
GOOGLE_GA4_REDIRECT_URI=http://localhost:3001/api/integrations/ga4/callback

# Adobe Analytics
# Create credentials: https://developer.adobe.com/console
ADOBE_CLIENT_ID=
ADOBE_CLIENT_SECRET=
ADOBE_REDIRECT_URI=http://localhost:3001/api/integrations/adobe-analytics/callback

# Meta Business (Facebook Pixel + Page Insights)
# Create app: https://developers.facebook.com/apps
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:3001/api/integrations/meta/callback

# ─── Token encryption ─────────────────────────
# 32-byte hex key used to encrypt OAuth tokens before they are written
# to disk. Required only if you use integrations. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTEGRATION_ENCRYPTION_KEY=
OAUTH_STATE_SECRET=

# ─── Scan limits (tunable) ────────────────────
# How many pages a single multi-page scan can crawl.
PAGE_LIMIT=200
# Audit-mode page and depth limits (the /audit/discover endpoint).
AUDIT_PAGE_LIMIT=5000
AUDIT_DEPTH_LIMIT=10
# Concurrency and politeness for multi-page scans.
SCAN_CONCURRENCY=3
CRAWL_DELAY_MS=300
# Per-IP rate limit for scan endpoints (requests per minute).
SCAN_RATE_LIMIT=20
